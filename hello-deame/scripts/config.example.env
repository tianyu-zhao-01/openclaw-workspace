# 复制为同目录下的 .env 并填写（勿提交 .env）
# cp config.example.env .env

# 飞书群 / 单聊自定义机器人 Webhook 完整 URL
FEISHU_WEBHOOK_URL=

# 微信侧任选其一：
# - 企业微信群机器人 Webhook
# - Server酱 SendKey 完整 URL（sctapi.ftqq.com / sc.ftqq.com）
WECHAT_WEBHOOK_URL=

# 可选：GitHub Token，提高 Search API 限额
GITHUB_TOKEN=
# 可选：明星项目最低 star，默认 10000
# GITHUB_MIN_STARS=10000
# 可选：逗号分隔 topic 列表
# GITHUB_AI_TOPICS=machine-learning,llm,deep-learning,artificial-intelligence

# 二选一（若同时配置，优先使用 OpenAI）：
# A) OpenAI 兼容 API —— 标题中文化 + GitHub 百字摘要（模型生成）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# B) 腾讯翻译君（需 pip install -r scripts/requirements-tmt.txt）—— 机翻标题与仓库说明，摘要为译后截断百字
# TENCENT_SECRET_ID=
# TENCENT_SECRET_KEY=
# TENCENT_TMT_REGION=ap-guangzhou
# 同时配置了 OpenAI 与腾讯时：auto=优先 OpenAI；tencent=强制腾讯；openai=强制 OpenAI
# BRIEF_TRANSLATE_BACKEND=auto
# 第二步模式：brief=编辑整理（默认）；translate=尽量直译
# BRIEF_LLM_MODE=brief
# 已配置 API 时：设为 0 则推送不包含文末英文原文（更短，适合飞书）
# BRIEF_APPEND_ENGLISH_ORIGINAL=1
